# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY

# DeepSeek — powers the FitAgent chat receptionist (/api/chat), via the
# OpenAI-compatible API (model deepseek-v4-flash). Server-side only (no
# NEXT_PUBLIC_ prefix). Get a key at https://platform.deepseek.com/. Restart
# `next dev` after adding/changing it.
DEEPSEEK_API_KEY=sk-YOUR-KEY
# Optional overrides (defaults shown):
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
